#include <stdio.h>

// Movimentação peças xadrez
// Peças: Torre, Bispo e Rainha

int main() {

    // Qtd movimentos das peças
    int movimentos_Torre = 5;
    int movimentos_Bispo = 5;
    int movimentos_Rainha = 8;

    int i; // variável de controle

    // TORRE anda 5 casas para a direita

    printf("Movimento da Torre: \n");
    
    for(i = 1; i <= movimentos_Torre; i++) {
        printf("Direita \n");
    }

    printf("\n");

    // BISPO anda 5 casas na diagonal (Cima + Direita)

    printf("Movimento do Bispo: \n");

    i = 1;

    while(i <= movimentos_Bispo) {

        printf("Cima, Direita \n");
        i++;
    }

    printf("\n");

    // RAINHA anda 8 casas para a esquerda

    printf("Movimento da Rainha: \n");

    i = 1;

    do {

        printf("Esquerda \n");

        i++;

    } while(i <= movimentos_Rainha);

    return 0;
}


